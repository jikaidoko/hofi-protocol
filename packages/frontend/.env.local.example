# HoFi Protocol — Variables de entorno para el frontend Next.js
# Copiar este archivo como .env.local y completar los valores.
# Las variables NEXT_PUBLIC_* son visibles en el browser.
# Las demás son solo servidor.

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En producción: https://hofi.app (o el dominio que se use)

# ─── JWT ──────────────────────────────────────────────────────────────────────
# La misma clave que usa el Tenzo Agent (Secret Manager: JWT_SECRET_KEY)
JWT_SECRET_KEY=

# ─── Tenzo Agent (Cloud Run) ──────────────────────────────────────────────────
# URL del servicio en Cloud Run
TENZO_AGENT_URL=https://hofi-tenzo-1080243330445.us-central1.run.app

# API key demo para autenticarse con el Tenzo (Secret Manager: DEMO_API_KEY)
DEMO_API_KEY=644834adec7c5ad08122f1e1cdf13d19f004bf7f6e6af119e38ca53698b1f1ad

# Contraseña del admin del Tenzo (alternativa a DEMO_API_KEY)
# TENZO_ADMIN_PASSWORD=

# ─── Voice Auth ───────────────────────────────────────────────────────────────
# Endpoint del servicio de biometría de voz.
# Por implementar en packages/telegram-bot o en el Tenzo Agent.
# VOICE_AUTH_URL=https://hofi-bot-qpxiby6ona-uc.a.run.app/voice-auth

# ─── Cloud SQL (PostgreSQL) ───────────────────────────────────────────────────
# En Cloud Run: dejar DB_SOCKET_PATH y omitir DB_HOST
# En local: dejar DB_HOST y correr Cloud SQL Auth Proxy

# Para Cloud Run (mismo socket que usa el Tenzo Agent):
# DB_SOCKET_PATH=/cloudsql/hofi-v2-2026:us-central1:hofi-db

# Para desarrollo local (Cloud SQL Auth Proxy en puerto 5432):
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=hofi_db
DB_USER=tenzo_user
DB_PASS=

# ─── OAuth Social Login (opcionales) ─────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# TELEGRAM_BOT_USERNAME=HoFiBot
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# ─── Mapbox (World View) ──────────────────────────────────────────────────────
# Token público de Mapbox para el mapa del WorldView
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Contratos on-chain (lectura pública) ─────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_HOCA_TOKEN=0x2a6339b63ec0344619923Dbf8f8B27cC5c9b40dc
NEXT_PUBLIC_HOLON_SBT=0x977E4eac99001aD8fe02D8d7f31E42E3d0Ffb036
NEXT_PUBLIC_TASK_REGISTRY=0xd9B253E6E1b494a7f2030f9961101fC99d3fD038

# HolonChain (Fuji Testnet) — para cuando se active ON_CHAIN en HolonChain
# NEXT_PUBLIC_HOLONCHAIN_RPC=http://34.122.241.26:9650/ext/bc/2iQdZzzFtdvWH2hpDm5ReijM8AtLdVmVMxGV4j4pWMz3LpoRzZ/rpc
# NEXT_PUBLIC_HOLONCHAIN_ID=73621
