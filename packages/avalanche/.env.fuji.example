# HolonChain Fuji Testnet — Environment Variables
# Copy to .env.fuji and fill in your values
# NEVER commit .env.fuji to git

# Your Avalanche node ID (format: NodeID-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX)
NODE_ID=NodeID-REPLACE_WITH_YOUR_NODE_ID

# Your wallet private key for deployment (WITHOUT 0x prefix)
# Generate a NEW wallet for testnet — never use mainnet keys
# Command: cast wallet new (from foundry) or avalanche key create
PRIVATE_KEY=REPLACE_WITH_YOUR_TESTNET_PRIVATE_KEY

# Fuji RPC (public endpoint)
FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc

# HolonSBT contract address on Ethereum Sepolia (for validator whitelist verification)
HOLON_SBT_ADDRESS=0x977E4eac99001aD8fe02D8d7f31E42E3d0Ffb036
